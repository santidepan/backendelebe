generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Unidad {
  id           Int          @id @default(autoincrement())
  nombre       String       @unique @db.VarChar(100)
  articulos    Articulo[]
  producciones Produccion[]
}

model Articulo {
  id                   String                  @id @default(cuid())
  label                String                  @db.VarChar(200)
  unidad_id            Int
  unidad               Unidad                  @relation(fields: [unidad_id], references: [id])
  descripcion_standard String?                 @db.Text
  producciones         Produccion[]
  etapasStandard       ArticuloEtapaStandard[]
  insumosStandard      ArticuloInsumoStandard[]
}

model RubroInsumo {
  id     String @id @default(cuid())
  label  String @db.VarChar(200)
  unidad String @db.VarChar(20)
}

model TipoEtapa {
  id                String                 @id @default(cuid())
  nombre            String                 @db.VarChar(200)
  talleres          TipoEtapaTaller[]
  etapas            Etapa[]
  articulosStandard ArticuloEtapaStandard[]
}

model Taller {
  id         String            @id @default(cuid())
  nombre     String            @db.VarChar(200)
  tiposEtapa TipoEtapaTaller[]
  etapas     Etapa[]
}

model TipoEtapaTaller {
  taller_id     String
  tipo_etapa_id String
  taller        Taller    @relation(fields: [taller_id], references: [id], onDelete: Cascade)
  tipoEtapa     TipoEtapa @relation(fields: [tipo_etapa_id], references: [id], onDelete: Cascade)

  @@id([taller_id, tipo_etapa_id])
}

model Usuario {
  id           String       @id @default(cuid())
  username     String       @unique @db.VarChar(100)
  password     String       @db.VarChar(255)
  nombre       String       @db.VarChar(200)
  role         String       @default("user") @db.VarChar(20)
  producciones Produccion[]
}

model Produccion {
  id                    String    @id @default(cuid())
  nombre                String    @db.VarChar(200)
  cliente               String?   @db.VarChar(200)
  unidad_id             Int
  unidad                Unidad    @relation(fields: [unidad_id], references: [id])
  articulo_id           String?
  articulo              Articulo? @relation(fields: [articulo_id], references: [id])
  descripcion           String?   @db.Text
  cantidad_prendas      Float?
  precio_venta          Float?
  fecha_inicio          String?   @db.VarChar(10)
  fecha_cierre_estimada String?   @db.VarChar(10)
  finalizada            Boolean   @default(false)
  fecha_fin_real        String?   @db.VarChar(10)
  vendedor_id           String?
  vendedor              Usuario?  @relation(fields: [vendedor_id], references: [id])
  insumos               Insumo[]
  etapas                Etapa[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Insumo {
  id             String     @id @default(cuid())
  produccion_id  String
  produccion     Produccion @relation(fields: [produccion_id], references: [id], onDelete: Cascade)
  rubro          String     @db.VarChar(200)
  descripcion    String?    @db.VarChar(300)
  costo_unitario Float?
  cantidad       Float?
  unidad_medida  String?    @db.VarChar(50)
}

model Etapa {
  id               String     @id @default(cuid())
  produccion_id    String
  produccion       Produccion @relation(fields: [produccion_id], references: [id], onDelete: Cascade)
  tipo_etapa_id    String?
  tipoEtapa        TipoEtapa? @relation(fields: [tipo_etapa_id], references: [id])
  taller_id        String?
  taller           Taller?    @relation(fields: [taller_id], references: [id])
  nombre           String?    @db.VarChar(200)
  taller_proveedor String?    @db.VarChar(200)
  fecha_inicio     String?    @db.VarChar(10)
  fecha_cierre     String?    @db.VarChar(10)
  estado           String     @default("pendiente") @db.VarChar(30)
  costo_total      Float?
  notas            String?    @db.Text
  pagada           Boolean    @default(false)
  fecha_pago       String?    @db.VarChar(10)
}

model ArticuloEtapaStandard {
  id             String    @id @default(cuid())
  articulo_id    String
  articulo       Articulo  @relation(fields: [articulo_id], references: [id], onDelete: Cascade)
  tipo_etapa_id  String
  tipoEtapa      TipoEtapa @relation(fields: [tipo_etapa_id], references: [id], onDelete: Cascade)
  costo_unitario Float     @default(0)
  orden          Int       @default(0)
}

model ArticuloInsumoStandard {
  id             String   @id @default(cuid())
  articulo_id    String
  articulo       Articulo @relation(fields: [articulo_id], references: [id], onDelete: Cascade)
  descripcion    String   @db.VarChar(300)
  costo_unitario Float    @default(0)
  orden          Int      @default(0)
}
