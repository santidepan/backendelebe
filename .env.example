# Cadena de conexión MySQL
# Formato: mysql://usuario:contraseña@host:puerto/nombre_base_datos
DATABASE_URL="mysql://root:password@localhost:3306/produccion_mgmt"

# Secreto para firmar los JWT (usá una cadena larga y aleatoria)
JWT_SECRET="cambia_esto_por_una_clave_secreta_larga"

# URL del frontend (para CORS). En producción ponés el dominio real.
FRONTEND_URL="http://localhost:5173"

# Puerto del servidor (opcional, default 3001)
PORT=3001

# Usuario admin inicial (se usa en el seed)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
